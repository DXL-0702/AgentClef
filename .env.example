AGENTCLEF_APP_NAME=AgentClef
AGENTCLEF_APP_VERSION=0.1.0
AGENTCLEF_ENVIRONMENT=development
AGENTCLEF_API_PORT=8000
AGENTCLEF_POSTGRES_DSN=postgresql+psycopg://agentclef:agentclef@localhost:5432/agentclef
